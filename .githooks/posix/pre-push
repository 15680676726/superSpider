#!/bin/sh

if command -v python >/dev/null 2>&1; then
  python scripts/git_branch_guard.py
elif command -v python3 >/dev/null 2>&1; then
  python3 scripts/git_branch_guard.py
elif command -v py >/dev/null 2>&1; then
  py -3 scripts/git_branch_guard.py
else
  echo "Python is required to run the branch guard." >&2
  exit 1
fi
