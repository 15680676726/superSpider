# superSpider runtime sample environment
# Copy to `.env` only if you want local environment-based configuration.

# Common provider API keys
OPENAI_API_KEY=
TAVILY_API_KEY=

# Optional embeddings override
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_FOLLOW_ACTIVE_PROVIDER=true

# Runtime diagnostics
COPAW_LOG_LEVEL=info
